{
  "name": "vision-classify",
  "description": "Document classification from images. Tests whether vision models can correctly identify document type, extract metadata, and return structured JSON. Targets the Paperless-ngx document processing use case.",
  "mode": "single-shot",
  "system_prompt": "Classify this document image. Return ONLY a JSON object with these fields:\n- type: invoice, receipt, recipe, floor_plan, letter, contract, or other\n- date: date as it appears in the document, or null\n- correspondent: sender, author, or organization name\n- title: short descriptive title in the document's language\n- language: ISO 639-1 code (e.g. de, en, fr)\n- total_amount: total amount as string if financial document, or null\n- currency: EUR, USD, etc. or null\n\nBe precise with numbers and dates. Respond with JSON only.",
  "max_tokens": 500,
  "temperature": 0.1,
  "turns": [
